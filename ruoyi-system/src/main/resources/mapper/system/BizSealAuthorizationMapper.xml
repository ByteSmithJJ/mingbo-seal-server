<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BizSealAuthorizationMapper">

    <resultMap type="BizSealAuthorization" id="BizSealAuthorizationResult">
        <result property="authId"         column="auth_id"         />
        <result property="sealId"         column="seal_id"         />
        <result property="targetType"     column="target_type"     />
        <result property="targetId"       column="target_id"       />
        <result property="authType"       column="auth_type"       />
        <result property="beginTime"      column="begin_time"      />
        <result property="endTime"        column="end_time"        />
        <result property="status"         column="status"          />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
        <result property="updateBy"       column="update_by"       />
        <result property="updateTime"     column="update_time"     />
        <result property="remark"         column="remark"          />
        <result property="sealName"       column="seal_name"       />
    </resultMap>

    <sql id="selectAuthorizationVo">
        select a.auth_id, a.seal_id, a.target_type, a.target_id, a.auth_type, a.begin_time, a.end_time,
               a.status, a.create_by, a.create_time, a.update_by, a.update_time, a.remark,
               s.seal_name
        from biz_seal_authorization a
        left join biz_seal s on a.seal_id = s.seal_id
    </sql>

    <select id="selectAuthorizationById" parameterType="Long" resultMap="BizSealAuthorizationResult">
        <include refid="selectAuthorizationVo"/>
        where a.auth_id = #{authId}
    </select>

    <select id="selectAuthorizationList" parameterType="BizSealAuthorization" resultMap="BizSealAuthorizationResult">
        <include refid="selectAuthorizationVo"/>
        <where>
            <if test="sealId != null">
                AND a.seal_id = #{sealId}
            </if>
            <if test="targetType != null and targetType != ''">
                AND a.target_type = #{targetType}
            </if>
            <if test="targetId != null">
                AND a.target_id = #{targetId}
            </if>
            <if test="authType != null and authType != ''">
                AND a.auth_type = #{authType}
            </if>
            <if test="status != null and status != ''">
                AND a.status = #{status}
            </if>
        </where>
        order by a.auth_id desc
    </select>

    <insert id="insertAuthorization" parameterType="BizSealAuthorization" useGeneratedKeys="true" keyProperty="authId">
        insert into biz_seal_authorization (
            <if test="sealId != null">seal_id,</if>
            <if test="targetType != null and targetType != ''">target_type,</if>
            <if test="targetId != null">target_id,</if>
            <if test="authType != null and authType != ''">auth_type,</if>
            <if test="beginTime != null">begin_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        )values(
            <if test="sealId != null">#{sealId},</if>
            <if test="targetType != null and targetType != ''">#{targetType},</if>
            <if test="targetId != null">#{targetId},</if>
            <if test="authType != null and authType != ''">#{authType},</if>
            <if test="beginTime != null">#{beginTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateAuthorization" parameterType="BizSealAuthorization">
        update biz_seal_authorization
        <set>
            <if test="sealId != null">seal_id = #{sealId},</if>
            <if test="targetType != null and targetType != ''">target_type = #{targetType},</if>
            <if test="targetId != null">target_id = #{targetId},</if>
            <if test="authType != null and authType != ''">auth_type = #{authType},</if>
            <if test="beginTime != null">begin_time = #{beginTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where auth_id = #{authId}
    </update>

    <delete id="deleteAuthorizationById" parameterType="Long">
        delete from biz_seal_authorization where auth_id = #{authId}
    </delete>

    <delete id="deleteAuthorizationByIds" parameterType="Long">
        delete from biz_seal_authorization where auth_id in
        <foreach item="authId" collection="array" open="(" separator="," close=")">
            #{authId}
        </foreach>
    </delete>

</mapper>

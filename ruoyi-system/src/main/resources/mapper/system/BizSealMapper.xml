<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BizSealMapper">

    <resultMap type="BizSeal" id="BizSealResult">
        <result property="sealId"         column="seal_id"         />
        <result property="sealName"       column="seal_name"       />
        <result property="sealCode"       column="seal_code"       />
        <result property="sealType"       column="seal_type"       />
        <result property="sealImage"      column="seal_image"      />
        <result property="status"         column="status"          />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
        <result property="updateBy"       column="update_by"       />
        <result property="updateTime"     column="update_time"     />
        <result property="remark"         column="remark"          />
    </resultMap>

    <sql id="selectSealVo">
        select seal_id, seal_name, seal_code, seal_type, seal_image, status, create_by, create_time, update_by, update_time, remark
        from biz_seal
    </sql>

    <select id="selectSealById" parameterType="Long" resultMap="BizSealResult">
        <include refid="selectSealVo"/>
        where seal_id = #{sealId}
    </select>

    <select id="selectSealList" parameterType="BizSeal" resultMap="BizSealResult">
        <include refid="selectSealVo"/>
        <where>
            <if test="sealName != null and sealName != ''">
                AND seal_name like concat('%', #{sealName}, '%')
            </if>
            <if test="sealCode != null and sealCode != ''">
                AND seal_code like concat('%', #{sealCode}, '%')
            </if>
            <if test="sealType != null and sealType != ''">
                AND seal_type = #{sealType}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by seal_id desc
    </select>

    <select id="checkSealCodeUnique" parameterType="String" resultMap="BizSealResult">
        <include refid="selectSealVo"/>
        where seal_code = #{sealCode} limit 1
    </select>

    <insert id="insertSeal" parameterType="BizSeal" useGeneratedKeys="true" keyProperty="sealId">
        insert into biz_seal (
            <if test="sealName != null and sealName != ''">seal_name,</if>
            <if test="sealCode != null and sealCode != ''">seal_code,</if>
            <if test="sealType != null and sealType != ''">seal_type,</if>
            <if test="sealImage != null and sealImage != ''">seal_image,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        )values(
            <if test="sealName != null and sealName != ''">#{sealName},</if>
            <if test="sealCode != null and sealCode != ''">#{sealCode},</if>
            <if test="sealType != null and sealType != ''">#{sealType},</if>
            <if test="sealImage != null and sealImage != ''">#{sealImage},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateSeal" parameterType="BizSeal">
        update biz_seal
        <set>
            <if test="sealName != null and sealName != ''">seal_name = #{sealName},</if>
            <if test="sealCode != null and sealCode != ''">seal_code = #{sealCode},</if>
            <if test="sealType != null">seal_type = #{sealType},</if>
            <if test="sealImage != null">seal_image = #{sealImage},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where seal_id = #{sealId}
    </update>

    <delete id="deleteSealById" parameterType="Long">
        delete from biz_seal where seal_id = #{sealId}
    </delete>

    <delete id="deleteSealByIds" parameterType="Long">
        delete from biz_seal where seal_id in
        <foreach item="sealId" collection="array" open="(" separator="," close=")">
            #{sealId}
        </foreach>
    </delete>

</mapper>
